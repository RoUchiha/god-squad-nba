# God Squad Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# NBA - BallDontLie API (free tier, sign up at balldontlie.io)
BALLDONTLIE_API_KEY=your_free_api_key_here

# Rate limiting secret (generate a random string: openssl rand -hex 32)
RATE_LIMIT_SECRET=your_random_secret_here

# Optional: Upstash Redis for production rate limiting
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# App URL (used for CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3001
