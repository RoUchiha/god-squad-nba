# God Squad Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# NBA - BallDontLie API (free tier, sign up at balldontlie.io)
BALLDONTLIE_API_KEY=your_free_api_key_here

# Required for /api/cron/nba-refresh. Generate at least 32 chars:
# openssl rand -hex 32
CRON_SECRET=your_random_cron_secret_here

# Optional: enables server-side LLM season explanations.
# Never expose this with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_REQUEST_LIMIT=250
OPENAI_TIMEOUT_MS=8000

# Public app URL. Browser-safe because it is not a secret.
NEXT_PUBLIC_APP_URL=http://localhost:3001
